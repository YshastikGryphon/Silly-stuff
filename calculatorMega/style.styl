*, *::before, *::after
  box-sizing border-box

html
  position relative

:root
  --clr-bg #000000
  --clr-1 #FAEB92
  --clr-2 #9929EA
  --clr-3 #FF5FCF
  --clr-4 #00F7FF
  --window-size 372px
  --window-padding 32px
  --window-btn-size 80px
  --window-btn-spacing 20px
  --font-family Arial, Helvetica, sans-serif
  --font-base 400 18px / 24px var(--font-family)
  --font-big 400 24px / 28px var(--font-family)
  --font-bigger 400 32px / 36px var(--font-family)
  --font-hero 600 60px / 72px var(--font-family)
  @media (max-width: 780px)
    --window-size 228px
    --window-padding 20px
    --window-btn-size 48px
    --window-btn-spacing 12px
    --font-base 400 16px / 22px var(--font-family)
    --font-big 400 22px / 26px var(--font-family)
    --font-bigger 400 26px / 28px var(--font-family)
    --font-hero 600 48px / 52px var(--font-family)

body
  position relative
  margin 0
  font var(--font-base)

section
  position relative
  height 100%
  display flex
  align-items center
  z-index 2

.container
  max-width 1200px
  width 100%
  padding 0 32px
  margin: 0 auto

.main
  position relative
  width 100vw
  height 100vh
  width 100dvw
  height 100dvh
  overflow hidden
  background var(--clr-bg)
  color var(--clr-1)
  z-index 2
  &__bg
    position absolute
    top 0
    right 0
    bottom 0
    left 0
    z-index -1
    transition all 4s ease
    pointer-events none
    &::after
      content ''
      position absolute
      top -100%
      left -100%
      right -100%
      bottom -100%
      opacity .4
      background radial-gradient(circle,rgba(87, 199, 133, .2) 0%, rgba(184, 148, 18, .1) 12%, rgba(0, 0, 0, 0) 32%)
      background-position 40vw 32vh 
      animation rotate 20s infinite linear
    &::before
      content ''
      position absolute
      top -100%
      left -100%
      right -100%
      bottom -100%
      opacity .4
      background radial-gradient(circle,rgba(63, 94, 251, .2) 0%, rgba(252, 70, 107, .2) 14%, rgba(0, 0, 0, 0) 56%)
      background-position -40vw -32vh 
      animation rotate 20s infinite linear

@keyframes rotate
  from
    transform rotate(0deg)
  to
    transform rotate(360deg)

.start
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  transition all 2s ease-out 
  &__main
    display flex
    justify-content center
    align-items center
    &-button
      background transparent
      outline none
      cursor pointer
      position relative
      padding 20px 32px 
      border-radius 12px
      border 3px solid var(--clr-1)
      color var(--clr-1)
      font var(--font-big)
      box-shadow 0 0 80px 0 rgba(255, 95, 207, .3)
      transition all .5s ease-in-out 
      &:hover
        color var(--clr-4)
        border-color var(--clr-4)
        box-shadow 0 0 80px 12px rgba(255, 95, 207, .6)

.intro
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  transition all 2s ease-out 
  &__main
    position relative
    width 100%
    &-title
      position absolute
      top 0
      left 0
      right 0
      text-align center
      font var(--font-hero)
      opacity 0
      transform translateY(20vh)
      &-1
        color var(--clr-1)
        animation textScroll 2s forwards ease-out
      &-2
        color var(--clr-1)
        animation textScroll 2s forwards ease-out
        animation-delay 1.35s
      &-3
        color var(--clr-4)
        animation textScroll 2s forwards ease-out
        animation-delay 2.7s
      &-4
        color var(--clr-1)
        animation textScroll 2s forwards ease-out
        animation-delay 3.95s
        & span
          color var(--clr-3)
      &-5
        color var(--clr-3)
        animation textScroll 2s forwards ease-out
        animation-delay 5s

@keyframes textScroll
  0% 
    opacity 0
    transform translateY(20vh) 
  25%
    opacity 1
    transform translateY(0) 
  75%
    opacity 1
    transform translateY(-3vh) 
  100% 
    opacity 0
    transform translateY(-20vh) 


.calculator
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  overflow auto
  transition all 2s ease-out 
  &__main
    position relative
    display flex
    justify-content center
    align-items center
    overflow hidden
    min-width 100dvw
    min-height 100dvh
    &::after
      content ''
      position absolute
      top 0
      left 0
      right 0
      bottom 0
      z-index 10
      cursor not-allowed
      display none
      pointer-events none
    &.--disable
      &::after
        display block
        pointer-events all
    &-window
      position relative
      width calc(var(--window-size) + var(--window-padding) * 2) 
      padding var(--window-padding)
      background #F7F8F0
      border-radius 32px
      display flex
      flex-direction column
      gap 20px
      overflow hidden
      &::before
        content ''
        position absolute
        top 0
        bottom 0
        left -800px
        right -200px
        background linear-gradient(110deg,#F7F8F0 0%, #F7F8F0 50%, #FFFFDE 58%, #F7F8F0 66%)
        animation prettyMetal 12s linear infinite
        pointer-events none
      &-head
        position relative
        z-index 2
        &-display
          width 100%
          min-height 136px
          background #9CD5FF
          padding 12px 20px 
          border-radius 16px
          color #355872
          display flex
          flex-direction column
          justify-content center
          align-items center
          & .text
            width 100%
            display flex
            align-items center
            font var(--font-base)
            font-weight 500
            & .big
              font var(--font-big)
              font-weight 500 
          & .result
            width 100%
            text-align right
            font var(--font-bigger)
            font-weight 700
          & .loader
            margin 0 auto 
            width 40px
            height 40px
            position relative
            &::before
              content ''
              position absolute
              top 0
              right 0
              bottom 0
              left 0
              background: linear-gradient(0deg, #355872 0%, transparent 100%)
              border-radius 50%
              animation loader 4s linear infinite
            &::after
              content ''
              position absolute
              top 10px
              right 10px
              bottom 10px
              left 10px
              background #9CD5FF
              border-radius 50%
            &-text
              position absolute
              top 100%
              left 50%
              width max-content
              font var(--font-base)
              color #355872
              transform translate(-50%, 0)
              & span
                width max-content
                display block
                animation appearToTop 1s ease forwards
      &-body
        position relative
        z-index 2
        display grid
        grid-template-columns repeat(4, var(--window-btn-size))
        grid-auto-rows var(--window-btn-size) 
        gap var(--window-btn-spacing) var(--window-btn-spacing) 
        &-btn
          outline none
          border none
          display flex
          justify-content center
          align-items center
          font var(--font-bigger)
          font-weight 500
          background #7AAACE
          color #fff
          border-radius 8px
          transition .25s ease
          &._action
            background #7acea0
          &._white-filter
            & span
              filter invert(.5) grayscale(1) brightness(20)
          &._result
            background #ce7aca
          &._2
            grid-column span 2
          &._3
            grid-column span 3
          &._4
            grid-column span 4
          &:hover
            background #8cbadd
            box-shadow 0 0 8px 2px rgba(153, 41, 234, .2)
          &:active
            background #7d92ce
            box-shadow 0 0 8px 2px rgba(153, 41, 234, 0)

@keyframes prettyMetal
  0%
    opacity 0
    transform translateX(-200px)
  25%
    opacity 1
    transform translateX(0)
  50%
    opacity 1
    transform translateX(400px)
  75%
    opacity 0
    transform translateX(600px)
  100%
    opacity 0
    transform translateX(0)

@keyframes loader
  from 
    transform rotate(0deg)
  to
    transform rotate(360deg)

@keyframes appearToTop
  from 
    opacity 0
    transform translateY(-32px)
  to
    opacity 1
    transform translateY(0)

.calculator__main-window-head-display
  & .text
    display flex
  & .result 
    display block
  & .loader
    display none
  &.--thinking
    & .text
      display none
    & .result 
      display none
    & .loader
      display block

// explode
.calculator__main-vfx
  position absolute
  top 0
  left 0
  right 0
  bottom 0
  z-index 20
  display none
  pointer-events all
  &-explosion
    position absolute
    font-size 320px
    line-height 100%
    text-shadow 0 0 40px #fff
    opacity 0
    transform scale(0)
    animation explosions .75s linear infinite
    &._1
      top -160px
      left -160px
    &._2
      top 160px
      right -160px
      animation-delay .32s
    &._3
      bottom -160px
      right -20px
      animation-delay .88s
    & span
      display block
      animation loader 36s linear infinite 

@keyframes explosions
  0%
    opacity 0
    transform scale(0)
  25%
    opacity 1
    transform scale(.2)
  50%
    opacity 1
    transform scale(1)
  100%
    opacity 0
    transform scale(1.2)



// stages
.main
  // start
  &.--start-screen
    & .start
      transform translateY(0)
      opacity 1
      visibility visible
      pointer-events all
    & .intro
      display none
      opacity 0
      visibility hidden
      pointer-events none
    & .calculator
      opacity 0
      display none
      visibility hidden
      pointer-events none
  // intro
  &.--intro-screen
    & .main__bg
      transform rotate(172deg)
    & .start
      transform translateY(-80vh)
      opacity 0
      visibility hidden
      pointer-events none
    & .intro
      display flex
      opacity 1
      visibility visible
      pointer-events all
    & .calculator
      transform translateY(80vh)
      opacity 0
      visibility hidden
      pointer-events none
  // calculator
  &.--calculator-screen
    & .main__bg
      transform rotate(284deg)
      @media (max-width: 780px)
        display none
    & .start
      display none
      opacity 0
      visibility hidden
      pointer-events none
    & .intro
      display none
      opacity 0
      visibility hidden
      pointer-events none
    & .calculator
      transform translateY(0)
      opacity 1
      visibility visible
      pointer-events all


// stages 2
.calculator__main
  &.--shake
    animation shaking 1s ease-in infinite
  &.--blow-up
    & .calculator__main-vfx
      display block

@keyframes shaking
  0%
    transform translate(0, 0)
  15%
    transform: translate(12px, 12px)
  25%
    transform: translate(-12px, -12px)
  30%
    transform: translate(12px, 52px)
  50%
    transform: translate(52px, 12px)
  85%
    transform: translate(-12px, 12px)
  75%
    transform: translate(-20px, 48px)
  90%
    transform: translate(12px, 52px)
  100%
    transform: translate(0, 0)
